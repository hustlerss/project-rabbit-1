<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cart | Project Rabbit</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family:'Segoe UI',sans-serif;">
<%- include('navbar.ejs') %>

<div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);padding:60px 0;text-align:center;color:#fff;">
  <h1 style="font-weight:900">🛒 Your Cart</h1>
</div>
<div class="container py-5" style="max-width:700px;">
  <div id="cartItems"></div>
  <div id="emptyCart" style="text-align:center;display:none;">
    <div style="font-size:80px;">🛒</div>
    <h3 class="text-muted mt-3">Your cart is empty</h3>
    <a href="/" class="btn btn-danger mt-3">Browse Projects</a>
  </div>
  <div id="cartTotal" style="display:none;background:#fff;border-radius:14px;padding:25px;box-shadow:0 4px 20px rgba(0,0,0,.08);">
    <div class="d-flex justify-content-between fw-bold mb-3" style="font-size:20px;">
      <span>Total:</span><span style="color:#e94560;" id="totalAmt">₹0</span>
    </div>
    <a href="/checkout" class="btn btn-danger w-100" style="padding:14px;font-size:16px;font-weight:700;">Proceed to Checkout →</a>
  </div>
</div>
<script>
let cart = JSON.parse(localStorage.getItem('projectRabbitCart') || '[]');
const el = document.getElementById('cartItems');
const totalEl = document.getElementById('cartTotal');
const emptyEl = document.getElementById('emptyCart');
if(!cart.length){emptyEl.style.display='block';}
else{
  totalEl.style.display='block';
  let total=0;
  cart.forEach((item,i)=>{
    total+=parseFloat(item.price||0);
    el.innerHTML += '<div style="background:#fff;border-radius:12px;padding:20px;box-shadow:0 2px 10px rgba(0,0,0,.06);margin-bottom:15px;display:flex;justify-content:space-between;align-items:center;"><div><strong>'+item.title+'</strong><br><small class=\'text-muted\'>'+item.type+'</small></div><div style=\'display:flex;align-items:center;gap:15px\'><span style=\'font-weight:800;font-size:18px;color:#e94560\'>₹'+item.price+'</span><button onclick=\'remove('+i+')' class=\'btn btn-outline-danger btn-sm\'>Remove</button></div></div>';
  });
  document.getElementById('totalAmt').textContent='₹'+total.toFixed(2);
}
function remove(i){ cart.splice(i,1); localStorage.setItem('projectRabbitCart',JSON.stringify(cart)); location.reload(); }
</script>
<%- include('footer.ejs') %>
</body>
</html>