<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project Languages | Project Rabbit</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family:'Segoe UI',sans-serif;">
<%- include('navbar.ejs') %>

<div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);padding:60px 0;text-align:center;color:#fff;">
  <h1 style="font-weight:900">Projects by Language</h1>
</div>
<div class="container py-5">
<div class="row g-4 text-center">
  <% [['Python','🐍','/ai-projects'],['Java','☕','/ready-project-details'],['PHP','🐘','/ready-project-details'],['JavaScript','⚡','/web-development-projects'],['Flutter','📱','/mobile-projects'],['React','⚛️','/fullstack-projects'],['MySQL','🗄️','/ready-project-details'],['MongoDB','🍃','/fullstack-projects']].forEach(l => { %>
  <div class="col-md-3 col-6">
    <a href="<%=l[2]%>" style="background:#fff;border-radius:14px;padding:30px;display:block;text-decoration:none;box-shadow:0 4px 20px rgba(0,0,0,.07);transition:transform .2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform=''">
      <div style="font-size:40px;"><%=l[1]%></div>
      <h5 style="color:#1a1a2e;font-weight:700;margin-top:10px;"><%=l[0]%></h5>
    </a>
  </div>
  <% }) %>
</div>
</div>
<%- include('footer.ejs') %>
</body>
</html>