<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Customized Projects | Project Rabbit</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family:'Segoe UI',sans-serif;">
<%- include('navbar.ejs') %>

<div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);padding:80px 0;text-align:center;color:#fff;">
  <h1 style="font-weight:900">Get a Custom Project</h1>
  <p style="opacity:.7">Tell us your requirements and we'll build it for you!</p>
</div>
<div class="container py-5" style="max-width:650px;">
  <div style="background:#fff;border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,.08);padding:40px;">
    <form method="POST" action="/submit_project">
      <div class="mb-3"><label class="form-label fw-semibold">Full Name</label><input type="text" name="name" class="form-control" required placeholder="Your Name"></div>
      <div class="mb-3"><label class="form-label fw-semibold">Email</label><input type="email" name="email" class="form-control" required placeholder="your@email.com"></div>
      <div class="mb-3"><label class="form-label fw-semibold">Phone</label><input type="tel" name="phone" class="form-control" placeholder="9876543210"></div>
      <div class="mb-3"><label class="form-label fw-semibold">Technology</label><input type="text" name="technology" class="form-control" placeholder="e.g. Python, Java, PHP..."></div>
      <div class="mb-3"><label class="form-label fw-semibold">Project Description</label><textarea name="description" class="form-control" rows="5" required placeholder="Describe your project requirements..."></textarea></div>
      <button type="submit" class="btn btn-danger w-100" style="padding:14px;font-size:16px;font-weight:700;">📩 Submit Request</button>
    </form>
  </div>
</div>
<%- include('footer.ejs') %>
</body>
</html>