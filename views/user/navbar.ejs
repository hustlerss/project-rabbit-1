<!-- ═══════════════════════════════════════════════════════════
     PROJECT RABBIT — Global User Navbar (included in all pages)
     Sticky, glassmorphism, theme: #0a0a1a bg | #e94560 accent
════════════════════════════════════════════════════════════ -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

<style>
  /* ─── RESET & BASE ─── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', sans-serif; }

  /* ─── STICKY NAVBAR ─── */
  .pr-navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 9999;
    background: rgba(10, 10, 26, 0.92);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid rgba(233, 69, 96, 0.18);
    padding: 0 0;
    transition: all 0.35s ease;
  }
  .pr-navbar.scrolled {
    background: rgba(10, 10, 26, 0.98);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
    border-bottom-color: rgba(233, 69, 96, 0.3);
  }
  .pr-navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 14px 24px;
    gap: 16px;
  }

  /* ─── BRAND ─── */
  .pr-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .pr-brand-icon {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, #e94560, #c4294a);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    box-shadow: 0 4px 14px rgba(233, 69, 96, 0.45);
    transition: transform 0.25s;
  }
  .pr-brand:hover .pr-brand-icon { transform: rotate(-6deg) scale(1.08); }
  .pr-brand-name {
    font-size: 18px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.3px;
  }
  .pr-brand-name span { color: #e94560; }

  /* ─── NAV LINKS ─── */
  .pr-nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
  }
  .pr-nav-links a {
    color: rgba(255,255,255,0.72);
    text-decoration: none;
    font-size: 13.5px;
    font-weight: 500;
    padding: 7px 13px;
    border-radius: 9px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .pr-nav-links a:hover,
  .pr-nav-links a.active {
    color: #fff;
    background: rgba(255,255,255,0.08);
  }
  .pr-nav-links a.active { color: #e94560; background: rgba(233,69,96,0.1); }

  /* ─── CART BUTTON ─── */
  .pr-btn-cart {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: linear-gradient(135deg, #e94560, #c4294a);
    color: #fff !important;
    padding: 9px 20px !important;
    border-radius: 11px !important;
    font-weight: 700 !important;
    font-size: 13.5px !important;
    box-shadow: 0 4px 18px rgba(233, 69, 96, 0.38);
    transition: all 0.25s !important;
  }
  .pr-btn-cart:hover {
    background: linear-gradient(135deg, #ff5572, #e94560) !important;
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 24px rgba(233, 69, 96, 0.5) !important;
    color: #fff !important;
  }

  /* ─── HAMBURGER ─── */
  .pr-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    border-radius: 8px;
    transition: background 0.2s;
  }
  .pr-hamburger:hover { background: rgba(255,255,255,0.07); }
  .pr-hamburger span {
    display: block;
    width: 24px; height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: all 0.3s;
  }
  .pr-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .pr-hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .pr-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ─── MOBILE DRAWER ─── */
  .pr-mobile-menu {
    display: none;
    flex-direction: column;
    background: rgba(10, 10, 26, 0.98);
    border-top: 1px solid rgba(233, 69, 96, 0.15);
    padding: 14px 20px 20px;
    gap: 4px;
  }
  .pr-mobile-menu.open { display: flex; }
  .pr-mobile-menu a {
    color: rgba(255,255,255,0.78);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    padding: 11px 14px;
    border-radius: 10px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .pr-mobile-menu a:hover { color: #fff; background: rgba(255,255,255,0.07); }
  .pr-mobile-menu a.cart-mobile {
    background: linear-gradient(135deg, #e94560, #c4294a);
    color: #fff;
    margin-top: 8px;
    justify-content: center;
    font-weight: 700;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .pr-nav-links { display: none; }
    .pr-hamburger { display: flex; }
  }
  @media (min-width: 901px) {
    .pr-mobile-menu { display: none !important; }
  }

  /* Body offset so content isn't hidden under fixed navbar */
  body { padding-top: 70px; }
</style>

<header>
  <nav class="pr-navbar" id="prNavbar" role="navigation" aria-label="Main navigation">
    <div class="pr-navbar-inner">

      <!-- Brand -->
      <a href="/" class="pr-brand" id="navBrand">
        <div class="pr-brand-icon">🐇</div>
        <span class="pr-brand-name">Project<span>Hub</span></span>
      </a>

      <!-- Desktop Nav Links -->
      <ul class="pr-nav-links" id="desktopNav">
        <li><a href="/" id="navHome"><i class="fas fa-home fa-xs" style="margin-right:4px;opacity:.7;"></i>Home</a></li>
        <li><a href="/ready-project-details" id="navReady"><i class="fas fa-rocket fa-xs" style="margin-right:4px;opacity:.7;"></i>Ready</a></li>
        <li><a href="/mini-project-details" id="navMini"><i class="fas fa-cubes fa-xs" style="margin-right:4px;opacity:.7;"></i>Mini</a></li>
        <li><a href="/bundle-project-details" id="navBundle"><i class="fas fa-gift fa-xs" style="margin-right:4px;opacity:.7;"></i>Bundle</a></li>
        <li><a href="/customized-project-details" id="navCustom"><i class="fas fa-pencil-ruler fa-xs" style="margin-right:4px;opacity:.7;"></i>Custom</a></li>
        <li><a href="/roadmaps" id="navRoadmap"><i class="fas fa-map fa-xs" style="margin-right:4px;opacity:.7;"></i>Roadmaps</a></li>
        <li><a href="/contact" id="navContact"><i class="fas fa-envelope fa-xs" style="margin-right:4px;opacity:.7;"></i>Contact</a></li>
        <li><a href="/my-orders" id="navOrders"><i class="fas fa-box fa-xs" style="margin-right:4px;opacity:.7;"></i>My Orders</a></li>
        <li><a href="/checkout" class="pr-btn-cart" id="navCart"><i class="fas fa-shopping-cart"></i> Cart</a></li>
      </ul>


      <!-- Hamburger -->
      <button class="pr-hamburger" id="prHamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div class="pr-mobile-menu" id="prMobileMenu" role="menu">
      <a href="/"><i class="fas fa-home fa-fw"></i> Home</a>
      <a href="/ready-project-details"><i class="fas fa-rocket fa-fw"></i> Ready Projects</a>
      <a href="/mini-project-details"><i class="fas fa-cubes fa-fw"></i> Mini Projects</a>
      <a href="/bundle-project-details"><i class="fas fa-gift fa-fw"></i> Bundle Projects</a>
      <a href="/customized-project-details"><i class="fas fa-pencil-ruler fa-fw"></i> Custom Projects</a>
      <a href="/roadmaps"><i class="fas fa-map fa-fw"></i> Roadmaps</a>
      <a href="/contact"><i class="fas fa-envelope fa-fw"></i> Contact</a>
      <a href="/my-orders"><i class="fas fa-box fa-fw"></i> My Orders</a>
      <a href="/checkout" class="cart-mobile"><i class="fas fa-shopping-cart"></i> View Cart</a>
    </div>
  </nav>
</header>

<script>
  // ─── Scroll effect ───
  const nav = document.getElementById('prNavbar');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // ─── Hamburger toggle ───
  const ham = document.getElementById('prHamburger');
  const mob = document.getElementById('prMobileMenu');
  ham.addEventListener('click', () => {
    const open = mob.classList.toggle('open');
    ham.classList.toggle('open', open);
    ham.setAttribute('aria-expanded', open);
  });

  // ─── Active link highlight ───
  const path = window.location.pathname;
  document.querySelectorAll('.pr-nav-links a, .pr-mobile-menu a').forEach(a => {
    if (a.getAttribute('href') === path || (path !== '/' && a.getAttribute('href') !== '/' && path.startsWith(a.getAttribute('href')))) {
      a.classList.add('active');
    }
  });
</script>