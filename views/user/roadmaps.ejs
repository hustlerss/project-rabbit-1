<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Learning Roadmaps | Project Rabbit</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family:'Segoe UI',sans-serif;">
<%- include('navbar.ejs') %>

<div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);padding:60px 0;text-align:center;color:#fff;">
  <h1 style="font-weight:900">Learning Roadmaps</h1>
  <p style="opacity:.7">Follow structured paths to master technologies</p>
</div>
<div class="container py-5">
<div class="row g-4">
<% roadmaps.forEach(r => { %>
<div class="col-md-4">
  <div style="background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.08);">
    <img src="/uploads/<%=r.image%>" style="width:100%;height:200px;object-fit:cover;" onerror="this.src='https://placehold.co/400x200?text=Roadmap'">
    <div style="padding:20px;">
      <span style="background:#e94560;color:#fff;border-radius:20px;padding:3px 12px;font-size:12px;"><%=r.category%></span>
      <h5 style="font-weight:700;margin:12px 0 8px;"><%=r.title%></h5>
      <p style="color:#888;font-size:14px;"><%=r.short_description%></p>
      <div style="color:#888;font-size:13px;">⏱ Duration: <%=r.duration%></div>
    </div>
  </div>
</div>
<% }) %>
<% if(!roadmaps.length){ %><div class="col-12 text-center py-5"><h4 class="text-muted">Roadmaps coming soon!</h4></div><% } %>
</div>
</div>
<%- include('footer.ejs') %>
</body>
</html>