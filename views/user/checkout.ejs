<%- include('navbar.ejs') %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout | Project Rabbit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #f4f6f9; }
        .checkout-wrap { max-width: 900px; margin: 40px auto; padding: 0 15px; }
        .checkout-card { background: #fff; border-radius: 16px; box-shadow: 0 4px 24px rgba(0,0,0,0.09); padding: 35px; }
        .order-summary { background: linear-gradient(135deg, #1a1a2e, #0f3460); color: #fff; border-radius: 14px; padding: 25px; }
        .order-summary h5 { color: #e94560; font-weight: 700; }
        .form-control, .form-select { border-radius: 10px; padding: 12px 15px; border: 1.5px solid #e0e0e0; font-size: 14px; }
        .form-control:focus { border-color: #e94560; box-shadow: 0 0 0 0.2rem rgba(233,69,96,0.15); }
        .btn-pay { background: linear-gradient(135deg, #e94560, #c4294a); border: none; color: #fff; padding: 14px 30px; border-radius: 12px; font-size: 16px; font-weight: 700; width: 100%; transition: all 0.3s; letter-spacing: 0.5px; }
        .btn-pay:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(233,69,96,0.4); color: #fff; }
        .btn-pay:disabled { background: #aaa; transform: none; }
        .secure-badge { text-align: center; color: #888; font-size: 13px; margin-top: 12px; }
        .price-tag { font-size: 32px; font-weight: 800; color: #e94560; }
        .rzp-logo { height: 22px; }
        .step-badge { background: #e94560; color: #fff; border-radius: 50%; width: 28px; height: 28px; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; }
        .section-title { font-weight: 700; color: #1a1a2e; margin-bottom: 18px; display: flex; align-items: center; gap: 10px; }
        #payment-success { display: none; }
        #payment-failed { display: none; }
    </style>
</head>
<body>
<div class="checkout-wrap">
    <h2 class="fw-bold mb-4" style="color:#1a1a2e;"><i class="fas fa-lock me-2" style="color:#e94560;"></i>Secure Checkout</h2>

    <div class="row g-4">
        <!-- Left: Customer form -->
        <div class="col-lg-7">
            <div class="checkout-card">
                <div class="section-title">
                    <span class="step-badge">1</span> Your Information
                </div>
                <form id="checkoutForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="buyerName" placeholder="Rohan Desai" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Email Address <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="buyerEmail" placeholder="rohan@example.com" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone Number <span class="text-danger">*</span></label>
                            <input type="tel" class="form-control" id="buyerPhone" placeholder="9876543210" maxlength="10" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">City</label>
                            <input type="text" class="form-control" id="buyerCity" placeholder="Mumbai">
                        </div>
                    </div>

                    <hr class="my-4">
                    <div class="section-title">
                        <span class="step-badge">2</span> Cart Summary
                    </div>

                    <!-- Dynamic cart items will be injected here -->
                    <div id="cartItemsList">
                        <div class="text-center py-4 text-muted">
                            <i class="fas fa-shopping-cart fa-2x mb-2"></i>
                            <p>Your cart is empty. <a href="/">Browse Projects</a></p>
                        </div>
                    </div>

                    <hr class="my-4">
                    <div class="section-title">
                        <span class="step-badge">3</span> Payment
                    </div>

                    <button type="button" class="btn-pay" id="payNowBtn" onclick="initiatePayment()">
                        <i class="fas fa-lock me-2"></i> Pay Now with Razorpay
                    </button>
                    <div class="secure-badge">
                        <i class="fas fa-shield-alt me-1 text-success"></i> 100% Secure Payment &nbsp;|&nbsp;
                        <img src="https://razorpay.com/assets/razorpay-logo.svg" class="rzp-logo" alt="Razorpay">
                    </div>
                </form>
            </div>

            <!-- Payment Success Message -->
            <div class="checkout-card mt-4 text-center" id="payment-success">
                <div style="font-size:60px;">🎉</div>
                <h3 class="text-success fw-bold mt-2">Payment Successful!</h3>
                <p class="text-muted">Your project is ready to download.</p>
                <a id="downloadLink" href="#" class="btn btn-success btn-lg mt-2">
                    <i class="fas fa-download me-2"></i>Download Project
                </a>
                <p class="mt-3 text-muted small">Payment ID: <code id="successPaymentId"></code></p>
            </div>

            <!-- Payment Failed Message -->
            <div class="checkout-card mt-4 text-center" id="payment-failed">
                <div style="font-size:60px;">❌</div>
                <h3 class="text-danger fw-bold mt-2">Payment Failed</h3>
                <p class="text-muted" id="failedMsg">Something went wrong. Please try again.</p>
                <button class="btn btn-outline-danger mt-2" onclick="location.reload()">Try Again</button>
            </div>
        </div>

        <!-- Right: Order Summary -->
        <div class="col-lg-5">
            <div class="order-summary sticky-top" style="top: 20px;">
                <h5><i class="fas fa-receipt me-2"></i>Order Summary</h5>
                <hr style="border-color:rgba(255,255,255,0.2);">
                <div id="summaryItems">
                    <p class="opacity-60" id="emptyCartMsg">No items in cart yet.</p>
                </div>
                <hr style="border-color:rgba(255,255,255,0.2);">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="opacity-75">Subtotal</span>
                    <span id="subtotalDisplay" class="price-tag">₹0</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-2">
                    <span class="opacity-75">GST (18%)</span>
                    <span id="gstDisplay" class="fw-bold">₹0</span>
                </div>
                <hr style="border-color:rgba(255,255,255,0.2);">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold fs-5">Total</span>
                    <span id="totalDisplay" class="price-tag" style="font-size:26px;">₹0</span>
                </div>
                <div class="mt-4">
                    <div class="d-flex align-items-center gap-2 mb-2" style="color:rgba(255,255,255,0.7);">
                        <i class="fas fa-check-circle text-success"></i> Instant Download
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-2" style="color:rgba(255,255,255,0.7);">
                        <i class="fas fa-check-circle text-success"></i> Source Code Included
                    </div>
                    <div class="d-flex align-items-center gap-2" style="color:rgba(255,255,255,0.7);">
                        <i class="fas fa-check-circle text-success"></i> 24/7 Support
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    // Razorpay Key from server
    const RAZORPAY_KEY = "<%= razorpay_key %>";

    // Load cart from localStorage
    let cart = JSON.parse(localStorage.getItem('projectRabbitCart') || '[]');

    function renderCart() {
        const listEl = document.getElementById('cartItemsList');
        const summaryEl = document.getElementById('summaryItems');
        const emptyMsg = document.getElementById('emptyCartMsg');

        if (!cart || cart.length === 0) {
            listEl.innerHTML = `<div class="text-center py-4 text-muted"><i class="fas fa-shopping-cart fa-2x mb-2"></i><p>Your cart is empty. <a href="/">Browse Projects</a></p></div>`;
            summaryEl.innerHTML = `<p class="opacity-60">No items in cart yet.</p>`;
            updateTotals(0);
            document.getElementById('payNowBtn').disabled = true;
            return;
        }

        document.getElementById('payNowBtn').disabled = false;

        let listHTML = '';
        let summaryHTML = '';
        let subtotal = 0;

        cart.forEach((item, idx) => {
            const price = parseFloat(item.price) || 0;
            subtotal += price;
            listHTML += `
                <div class="d-flex justify-content-between align-items-center mb-3 p-2 border rounded-3">
                    <div>
                        <strong>${item.title}</strong>
                        <span class="badge bg-secondary ms-2" style="font-size:10px;">${item.type}</span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-success fw-bold">₹${price.toFixed(2)}</span>
                        <button class="btn btn-sm btn-outline-danger rounded-circle" onclick="removeFromCart(${idx})" style="width:28px;height:28px;padding:0;">✕</button>
                    </div>
                </div>`;
            summaryHTML += `<div class="d-flex justify-content-between mb-2" style="color:rgba(255,255,255,0.8);"><span style="max-width:200px;">${item.title}</span><span>₹${price.toFixed(2)}</span></div>`;
        });

        listEl.innerHTML = listHTML;
        summaryEl.innerHTML = summaryHTML;
        updateTotals(subtotal);
    }

    function updateTotals(subtotal) {
        const gst = subtotal * 0.18;
        const total = subtotal + gst;
        document.getElementById('subtotalDisplay').textContent = '₹' + subtotal.toFixed(2);
        document.getElementById('gstDisplay').textContent = '₹' + gst.toFixed(2);
        document.getElementById('totalDisplay').textContent = '₹' + total.toFixed(2);
    }

    function removeFromCart(idx) {
        cart.splice(idx, 1);
        localStorage.setItem('projectRabbitCart', JSON.stringify(cart));
        renderCart();
    }

    async function initiatePayment() {
        const name = document.getElementById('buyerName').value.trim();
        const email = document.getElementById('buyerEmail').value.trim();
        const phone = document.getElementById('buyerPhone').value.trim();

        if (!name || !email || !phone) {
            alert('⚠️ Please fill in all required fields (Name, Email, Phone).');
            return;
        }
        if (!/^\d{10}$/.test(phone)) {
            alert('⚠️ Please enter a valid 10-digit phone number.');
            return;
        }
        if (!cart || cart.length === 0) {
            alert('⚠️ Your cart is empty!');
            return;
        }

        const subtotal = cart.reduce((s, i) => s + parseFloat(i.price || 0), 0);
        const total = subtotal + (subtotal * 0.18);
        const firstItem = cart[0]; // For single-item checkout

        document.getElementById('payNowBtn').disabled = true;
        document.getElementById('payNowBtn').textContent = '⏳ Creating Order...';

        try {
            const resp = await fetch('/create-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    amount: total.toFixed(2),
                    currency: 'INR',
                    projectTitle: cart.map(i => i.title).join(', '),
                    projectId: firstItem.id,
                    projectType: firstItem.type
                })
            });

            const data = await resp.json();

            if (!data.success) {
                throw new Error(data.message || 'Order creation failed');
            }

            const options = {
                key: RAZORPAY_KEY,
                amount: data.amount,
                currency: data.currency,
                name: 'Project Rabbit',
                description: firstItem.title,
                order_id: data.orderId,
                prefill: { name, email, contact: phone },
                theme: { color: '#e94560' },
                modal: { ondismiss: function() {
                    document.getElementById('payNowBtn').disabled = false;
                    document.getElementById('payNowBtn').innerHTML = '<i class="fas fa-lock me-2"></i> Pay Now with Razorpay';
                }},
                handler: async function(response) {
                    await verifyPayment(response, firstItem, total.toFixed(2), name, email, phone);
                }
            };

            const rzp = new Razorpay(options);
            rzp.on('payment.failed', function(resp) {
                document.getElementById('payment-failed').style.display = 'block';
                document.getElementById('failedMsg').textContent = resp.error.description || 'Payment failed.';
                document.getElementById('checkoutForm').style.display = 'none';
                document.getElementById('payNowBtn').disabled = false;
                document.getElementById('payNowBtn').innerHTML = '<i class="fas fa-lock me-2"></i> Pay Now with Razorpay';
            });
            rzp.open();

        } catch (err) {
            console.error(err);
            alert('❌ Error: ' + err.message);
            document.getElementById('payNowBtn').disabled = false;
            document.getElementById('payNowBtn').innerHTML = '<i class="fas fa-lock me-2"></i> Pay Now with Razorpay';
        }
    }

    async function verifyPayment(rzpResp, item, amount, name, email, phone) {
        try {
            const vResp = await fetch('/verify-payment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    razorpay_order_id: rzpResp.razorpay_order_id,
                    razorpay_payment_id: rzpResp.razorpay_payment_id,
                    razorpay_signature: rzpResp.razorpay_signature,
                    projectId: item.id,
                    projectType: item.type,
                    projectTitle: item.title,
                    amount: amount,
                    buyerName: name,
                    buyerEmail: email,
                    buyerPhone: phone
                })
            });

            const vData = await vResp.json();

            if (vData.success) {
                // Clear cart
                localStorage.removeItem('projectRabbitCart');

                // Show success
                document.getElementById('checkoutForm').style.display = 'none';
                document.getElementById('payment-success').style.display = 'block';
                document.getElementById('successPaymentId').textContent = vData.paymentId;
                document.getElementById('downloadLink').href = `/download/${vData.paymentId}/${item.type}/${item.id}`;
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } else {
                document.getElementById('payment-failed').style.display = 'block';
                document.getElementById('failedMsg').textContent = vData.message || 'Verification failed.';
                document.getElementById('checkoutForm').style.display = 'none';
            }
        } catch (err) {
            console.error('Verification error:', err);
            alert('Payment recorded but verification failed. Contact support with Payment ID: ' + rzpResp.razorpay_payment_id);
        }
    }

    // Init on page load
    renderCart();
</script>
<%- include('footer.ejs') %>