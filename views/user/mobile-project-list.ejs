<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mobile App Projects | Project Rabbit</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="font-family:'Segoe UI',sans-serif;background:#f9fafb;">
<%- include('navbar.ejs') %>

<div style="background:linear-gradient(135deg,#1a1a2e,#0f3460);padding:70px 0;text-align:center;color:#fff;">
  <h1 style="font-weight:900;">📱 Mobile App Projects</h1>
  <p style="opacity:.7;">Android (Java/Kotlin), Flutter & React Native app projects with full source code</p>
</div>
<div class="container py-5">
<div class="row g-4">
<% mobile_projects.forEach(p => { %>
<div class="col-md-4">
  <div class="card h-100 shadow-sm border-0" style="border-radius:14px;overflow:hidden;transition:transform .2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform=''">
    <img src="/uploads/<%=p.ProjectImage%>" class="card-img-top" style="height:200px;object-fit:cover;" onerror="this.src='https://placehold.co/400x200?text=Project+Rabbit'">
    <div class="card-body">
      <span class="badge bg-danger mb-2"><%=p.ProjectCategory||p.ProjectType||'Mobile App'%></span>
      <h5 class="fw-bold"><%=p.ProjectTitle%></h5>
      <p class="text-muted small"><%=p.ProjectDescription?p.ProjectDescription.substring(0,100)+'...':''%></p>
    </div>
    <div class="card-footer bg-white border-0 pb-3 px-3 d-flex justify-content-between align-items-center">
      <span style="font-size:20px;font-weight:800;color:#e94560;">₹<%=p.Price%></span>
      <a href="/single-mobile-project/<%=p.ProjectID%>" class="btn btn-danger btn-sm">View Details</a>
    </div>
  </div>
</div>
<% }) %>
<% if(!mobile_projects.length){ %><div class="col-12 text-center py-5"><h4 class="text-muted">No projects available yet.</h4><a href="/" class="btn btn-danger mt-3">Back to Home</a></div><% } %>
</div>
</div>
<%- include('footer.ejs') %>
</body>
</html>
