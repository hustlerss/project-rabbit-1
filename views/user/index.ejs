  .cat-img-wrap { height: 180px; overflow: hidden; position: relative; }
  .cat-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
  .cat-card:hover .cat-img-wrap img { transform: scale(1.08); }
  .cat-img-wrap .cat-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.65)); }
  .cat-badge { position: absolute; top: 12px; left: 12px; background: #e94560; color: #fff; font-size: 11px; font-weight: 700; padding: 5px 12px; border-radius: 20px; }
  .cat-body { padding: 18px 20px 22px; }
  .cat-icon-wrap { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 12px; }
  .cat-title { font-weight: 800; font-size: 16px; color: #0a0a1a; margin-bottom: 6px; }
  .cat-desc { color: #6b7280; font-size: 13px; line-height: 1.5; margin-bottom: 14px; }
  .cat-price { font-weight: 800; font-size: 18px; color: #e94560; }
  .cat-arrow { width: 32px; height: 32px; background: #f3f4f6; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
  .cat-card:hover .cat-arrow { background: #e94560; color: #fff; }

  /* ── FEATURES ── */
  .feature-card { background: #fff; border-radius: 20px; padding: 35px 30px; border: 1px solid rgba(0,0,0,0.07); transition: all 0.3s; box-shadow: 0 2px 15px rgba(0,0,0,0.04); }
  .feature-card:hover { transform: translateY(-6px); box-shadow: 0 15px 40px rgba(0,0,0,0.1); border-color: #e94560; }
  .feature-icon { width: 64px; height: 64px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px; margin-bottom: 20px; }
  .feature-card h5 { font-weight: 800; font-size: 18px; color: #0a0a1a; margin-bottom: 10px; }
  .feature-card p { color: #6b7280; font-size: 14px; line-height: 1.7; margin: 0; }

  /* ── HOW IT WORKS ── */
  .step-card { text-align: center; padding: 20px; }
  .step-number { width: 60px; height: 60px; background: linear-gradient(135deg, #e94560, #c4294a); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 900; margin: 0 auto 20px; box-shadow: 0 8px 20px rgba(233,69,96,0.35); }
  .step-card h5 { font-weight: 800; color: #0a0a1a; margin-bottom: 10px; }
  .step-card p { color: #6b7280; font-size: 14px; }
  .step-connector { height: 2px; background: linear-gradient(to right, #e94560, transparent); margin-top: 30px; }

  /* ── TESTIMONIALS ── */
