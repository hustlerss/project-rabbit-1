  .section-tag { color: #e94560; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 12px; }
  .section-heading { font-size: clamp(28px, 4vw, 42px); font-weight: 900; color: #0a0a1a; line-height: 1.2; }
  .section-sub { color: #6b7280; font-size: 16px; margin-top: 12px; line-height: 1.7; }

  /* ── CATEGORIES ── */
