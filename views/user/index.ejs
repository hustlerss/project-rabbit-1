  .cta-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(233,69,96,0.2) 0%, transparent 70%); }
  .cta-section h2 { font-size: clamp(30px, 5vw, 50px); font-weight: 900; color: #fff; margin-bottom: 20px; }
  .cta-section p { color: rgba(255,255,255,0.65); font-size: 18px; margin-bottom: 40px; }

  /* ── FOOTER ── */
  .footer { background: #0a0a1a; color: rgba(255,255,255,0.7); padding: 70px 0 30px; }
  .footer-brand { color: #e94560; font-weight: 900; font-size: 22px; }
  .footer-desc { color: rgba(255,255,255,0.5); font-size: 14px; margin-top: 12px; line-height: 1.7; }
  .footer h6 { color: #fff; font-weight: 700; margin-bottom: 18px; font-size: 14px; letter-spacing: 0.5px; }
  .footer a { color: rgba(255,255,255,0.55); text-decoration: none; font-size: 14px; display: block; margin-bottom: 10px; transition: color 0.2s; }
  .footer a:hover { color: #e94560; }
  .footer-divider { border-color: rgba(255,255,255,0.1); margin: 40px 0 25px; }
  .footer-bottom { color: rgba(255,255,255,0.4); font-size: 13px; }

  /* ── SCROLL REVEAL ── */
  .reveal { opacity: 0; transform: translateY(30px); transition: all 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ── SEARCH BAR ── */
  .search-wrap { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.15); border-radius: 14px; padding: 5px; display: flex; max-width: 480px; margin: 30px auto 0; }
  .search-wrap input { background: transparent; border: none; color: #fff; padding: 10px 16px; flex: 1; font-size: 14px; outline: none; }
  .search-wrap input::placeholder { color: rgba(255,255,255,0.4); }
  .search-wrap button { background: #e94560; border: none; color: #fff; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; }

  /* Responsive */
  @media(max-width:768px) { .hero { padding-top: 100px; } .hero h1 { font-size: 32px; } }
</style>
</head>
