  .hero-content { position: relative; z-index: 2; text-align: center; padding: 40px 20px; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(233,69,96,0.15); border: 1px solid rgba(233,69,96,0.35); color: #e94560; padding: 8px 20px; border-radius: 50px; font-size: 13px; font-weight: 600; margin-bottom: 30px; }
