    background: linear-gradient(135deg, #e94560, #c4294a);
    padding: 50px 0;
  }
  .stat-item { text-align: center; color: #fff; }
  .stat-num { font-size: 44px; font-weight: 900; line-height: 1; }
  .stat-lbl { font-size: 14px; opacity: 0.8; margin-top: 5px; }

  /* ── SECTION COMMONS ── */
