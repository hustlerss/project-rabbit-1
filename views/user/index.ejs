  .hero p { color: rgba(255,255,255,0.65); font-size: 18px; max-width: 600px; margin: 0 auto 40px; line-height: 1.7; }
  .hero-btns { display: flex; gap: 15px; justify-content: center; flex-wrap: wrap; }
  .btn-primary-hero { background: linear-gradient(135deg, #e94560, #c4294a); color: #fff; padding: 16px 38px; border-radius: 14px; text-decoration: none; font-weight: 700; font-size: 16px; border: none; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px; box-shadow: 0 8px 30px rgba(233,69,96,0.4); }
  .btn-primary-hero:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(233,69,96,0.5); color: #fff; }
  .btn-outline-hero { background: transparent; color: #fff; padding: 16px 38px; border-radius: 14px; text-decoration: none; font-weight: 600; font-size: 16px; border: 2px solid rgba(255,255,255,0.25); transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px; }
  .btn-outline-hero:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.5); transform: translateY(-2px); }

  /* Hero floating cards */
  .hero-cards { display: flex; gap: 12px; justify-content: center; margin-top: 50px; flex-wrap: wrap; }
  .hero-mini-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 12px 18px; color: rgba(255,255,255,0.8); font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
