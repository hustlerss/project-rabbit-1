<script>
// ─── Scroll Reveal ───
const reveals = document.querySelectorAll('.reveal');
const ro = new IntersectionObserver((entries) => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) {
      setTimeout(() => entry.target.classList.add('visible'), i * 70);
      ro.unobserve(entry.target);
    }
  });
}, { threshold: 0.07 });
reveals.forEach(el => ro.observe(el));

// ─── Counter Animation ───
function animateCounter(el, target) {
  const suffix = target >= 10000 ? '+' : target >= 100 ? '+' : '';
  let count = 0;
  const inc = target / 55;
  const t = setInterval(() => {
    count += inc;
    if (count >= target) {
      el.textContent = target.toLocaleString('en-IN') + suffix;
      clearInterval(t);
    } else {
      el.textContent = Math.floor(count).toLocaleString('en-IN') + suffix;
    }
  }, 28);
}
const counterObs = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const target = +entry.target.dataset.target;
      if (target) animateCounter(entry.target, target);
      counterObs.unobserve(entry.target);
    }
  });
}, { threshold: 0.3 });
document.querySelectorAll('[data-target]').forEach(el => counterObs.observe(el));

// ─── Search ───
function searchProject(e) {
  if (e) e.preventDefault();
  const q = document.getElementById('heroSearch').value.trim();
  if (q) {
    window.location.href = '/ready-project-details?search=' + encodeURIComponent(q);
  } else {
    window.location.href = '/ready-project-details';
  }
}
</script>

