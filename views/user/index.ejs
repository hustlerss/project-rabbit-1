  .hero-orb-2 { position: absolute; width: 400px; height: 400px; border-radius: 50%; background: radial-gradient(circle, rgba(79,70,229,0.2) 0%, transparent 70%); bottom: -50px; left: -80px; animation: float 10s ease-in-out infinite reverse; }
