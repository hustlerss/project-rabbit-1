<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #030305;
    --bg-surface: #0a0a0f;
    --bg-card: rgba(255, 255, 255, 0.02);
    --border: rgba(255, 255, 255, 0.08);
    --accent: #e94560;
    --accent-glow: rgba(233, 69, 96, 0.4);
    --cyan: #00f2fe;
    --cyan-glow: rgba(0, 242, 254, 0.4);
    --text-main: #ffffff;
    --text-muted: #8a8a93;
  }
  
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  body {
    font-family: 'Outfit', sans-serif;
    background-color: var(--bg);
    color: var(--text-main);
    overflow-x: hidden;
    cursor: none; /* Custom cursor fallback */
  }

  html { scroll-behavior: smooth; }
  
  a { text-decoration: none; color: inherit; }

  /* ── CUSTOM CURSOR ── */
  .cursor-dot { width: 6px; height: 6px; background: var(--cyan); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999; top: 0; left: 0; transform: translate(-50%, -50%); transition: width 0.2s, height 0.2s; box-shadow: 0 0 10px var(--cyan); }
  .cursor-ring { width: 36px; height: 36px; border: 1.5px solid var(--accent); border-radius: 50%; position: fixed; pointer-events: none; z-index: 9998; top: 0; left: 0; transform: translate(-50%, -50%); transition: width 0.3s, height 0.3s, background 0.3s, border-color 0.3s; }
  
  /* Selectors for noise overlay */
  .noise-bg {
    position: fixed; inset: 0; z-index: 5000; pointer-events: none; opacity: 0.03;
    background: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');
  }

  /* ── NAVBAR ── */
  .navbar-master {
    background: rgba(3, 3, 5, 0.4);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--border);
    position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
    padding: 18px 0; transition: all 0.4s ease;
  }
  .navbar-master .brand { font-size: 24px; font-weight: 800; color: var(--text-main); letter-spacing: -0.5px; display: flex; align-items: center; gap: 8px; }
  .navbar-master .brand span { color: var(--accent); }
  .nav-links a { color: var(--text-muted); font-weight: 500; font-size: 15px; margin: 0 12px; transition: color 0.3s; position: relative; }
  .nav-links a:hover { color: var(--text-main); }
  .nav-links a::after { content: ''; position: absolute; bottom: -5px; left: 50%; width: 0; height: 2px; background: var(--cyan); transition: all 0.3s; transform: translateX(-50%); }
  .nav-links a:hover::after { width: 100%; box-shadow: 0 0 8px var(--cyan); }
  .nav-cart-btn { background: rgba(255,255,255,0.05); border: 1px solid var(--border); color: #fff; padding: 10px 22px; border-radius: 50px; font-weight: 600; font-size: 14px; transition: all 0.3s; }
  .nav-cart-btn:hover { background: var(--text-main); color: var(--bg); transform: translateY(-2px); }

  /* ── HERO ── */
  .hero-master {
    position: relative; min-height: 100vh; display: flex; align-items: center; justify-content: center;
    padding-top: 100px; overflow: hidden;
  }
  .hero-glow-1 { position: absolute; width: 600px; height: 600px; background: var(--accent-glow); filter: blur(120px); border-radius: 50%; top: -10%; right: -10%; opacity: 0.6; z-index: 0; }
  .hero-glow-2 { position: absolute; width: 500px; height: 500px; background: var(--cyan-glow); filter: blur(120px); border-radius: 50%; bottom: -10%; left: -10%; opacity: 0.5; z-index: 0; }
  .hero-grid-bg {
    position: absolute; inset: 0; z-index: 1;
    background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 50px 50px; opacity: 0.2;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  }
  
  .hero-content { position: relative; z-index: 10; text-align: center; max-width: 900px; }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 10px; padding: 8px 24px;
    background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 50px;
    font-size: 14px; font-weight: 500; color: #fff; margin-bottom: 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2); backdrop-filter: blur(10px);
  }
  .hero-pill .dot-pulse { width: 8px; height: 8px; background: #10b981; border-radius: 50%; box-shadow: 0 0 10px #10b981; animation: pulse 2s infinite; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.7); } 70% { box-shadow: 0 0 0 10px rgba(16,185,129,0); } 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); } }

  .hero-title { font-size: clamp(48px, 8vw, 90px); font-weight: 900; line-height: 1.05; letter-spacing: -2px; margin-bottom: 24px; text-transform: uppercase; }
  .text-gradient { background: linear-gradient(135deg, #fff 0%, var(--text-muted) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
  .text-stroke { color: transparent; -webkit-text-stroke: 1.5px rgba(255,255,255,0.3); font-style: italic; }
  
  .hero-subtitle { font-size: clamp(16px, 2vw, 20px); color: var(--text-muted); font-weight: 400; max-width: 600px; margin: 0 auto 40px; line-height: 1.6; }
  
  .hero-actions { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
  .btn-neo {
    background: var(--text-main); color: var(--bg); padding: 16px 40px; border-radius: 50px;
    font-weight: 700; font-size: 16px; transition: all 0.3s; display: inline-flex; align-items: center; gap: 10px;
  }
  .btn-neo:hover { background: var(--cyan); color: var(--bg); box-shadow: 0 0 20px rgba(0,242,254,0.4); transform: scale(1.05); }
  .btn-ghost {
    background: rgba(255,255,255,0.02); color: var(--text-main); padding: 16px 40px; border-radius: 50px; border: 1px solid var(--border);
    font-weight: 600; font-size: 16px; transition: all 0.3s; backdrop-filter: blur(10px);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); transform: scale(1.05); }

  /* ── MARQUEE ── */
  .marquee-wrap { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 25px 0; background: var(--bg-surface); overflow: hidden; position: relative; }
  .marquee-content { display: flex; white-space: nowrap; font-size: 20px; font-weight: 600; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; }
  .marquee-content span { padding: 0 40px; display: inline-flex; align-items: center; gap: 20px; }
  .marquee-content span i { color: var(--accent); }

  /* ── BENTO GRID CATEGORIES ── */
  .section-master { padding: 120px 0; position: relative; z-index: 5; }
  .sec-heading { text-align: center; margin-bottom: 60px; }
  .sec-heading .tag { color: var(--cyan); font-weight: 700; letter-spacing: 3px; font-size: 13px; text-transform: uppercase; margin-bottom: 15px; display: block; }
  .sec-heading h2 { font-size: clamp(32px, 5vw, 56px); font-weight: 800; letter-spacing: -1px; line-height: 1.1; }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(220px, auto);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }
  @media(max-width: 991px) { .bento-grid { grid-template-columns: repeat(2, 1fr); } }
  @media(max-width: 768px) { .bento-grid { display: flex; flex-direction: column; } }

  .bento-card {
    background: var(--bg-surface); border: 1px solid var(--border); border-radius: 24px;
    padding: 30px; position: relative; overflow: hidden; display: flex; flex-direction: column;
    justify-content: flex-end; z-index: 1; transition: border-color 0.4s;
    text-decoration: none !important; color: var(--text-main) !important; cursor: none;
  }
  .bento-card:hover { border-color: rgba(255,255,255,0.2); }
  
  .bento-card::before {
    content: ''; position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); opacity: 0.8;
  }
  /* BGs for cards */
  .bento-bg { position: absolute; inset: 0; background-size: cover; background-position: center; z-index: -2; opacity: 0.4; transition: transform 0.6s ease; filter: grayscale(50%); }
  .bento-card:hover .bento-bg { transform: scale(1.05); filter: grayscale(0%); opacity: 0.6;}
  
  .bento-large { grid-column: span 2; grid-row: span 2; }
  .bento-wide { grid-column: span 2; grid-row: span 1; }
  .bento-tall { grid-column: span 1; grid-row: span 2; }
  
  .bento-icon { width: 50px; height: 50px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px); border: 1px solid var(--border); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; position: absolute; top: 30px; left: 30px; }
  .bento-card h3 { font-size: 26px; font-weight: 700; margin-bottom: 8px; }
  .bento-card p { color: var(--text-muted); font-size: 15px; margin-bottom: 0; max-width: 90%; }
  
  .bento-badge { position: absolute; top: 30px; right: 30px; background: var(--accent); color: #fff; font-size: 11px; font-weight: 800; padding: 6px 14px; border-radius: 30px; text-transform: uppercase; letter-spacing: 1px; }

  /* ── STATS TYPOGRAPHY ── */
  .stats-wrap { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 30px; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 80px 0; background: rgba(10,10,15,0.5); }
  .stat-block { text-align: center; flex: 1; min-width: 200px; }
  .stat-number { font-size: clamp(60px, 8vw, 100px); font-weight: 900; line-height: 1; -webkit-text-stroke: 1px rgba(255,255,255,0.4); color: transparent; transition: color 0.4s; font-family: 'Outfit'; }
  .stat-block:hover .stat-number { color: var(--text-main); -webkit-text-stroke: 2px transparent; text-shadow: 0 0 30px rgba(255,255,255,0.3); }
  .stat-label { font-size: 15px; color: var(--cyan); font-weight: 600; text-transform: uppercase; letter-spacing: 2px; margin-top: 10px; }

  /* ── HOW IT WORKS STEPS ── */
  .step-list { display: flex; gap: 40px; margin-top: 60px; flex-wrap: wrap; }
  .step-item { flex: 1; min-width: 300px; background: var(--bg-surface); padding: 50px 40px; border-radius: 24px; border: 1px solid var(--border); position: relative; }
  .step-num { position: absolute; top: -30px; left: 40px; font-size: 80px; font-weight: 900; color: transparent; -webkit-text-stroke: 1px rgba(255,255,255,0.1); }
  .step-item h4 { font-size: 22px; font-weight: 700; margin-bottom: 15px; position: relative; z-index: 2; color: #fff; }
  .step-item p { color: var(--text-muted); font-size: 16px; line-height: 1.6; position: relative; z-index: 2; }

  /* ── CTA MEGA ── */
  .cta-mega { margin: 100px 0; border-radius: 30px; background: linear-gradient(135deg, var(--bg-surface), #120e1a); border: 1px solid var(--border); padding: 100px 40px; text-align: center; position: relative; overflow: hidden; }
  .cta-mega::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 80%; height: 100%; background: radial-gradient(ellipse at top, var(--accent-glow) 0%, transparent 70%); pointer-events: none; }
  .cta-mega h2 { font-size: clamp(36px, 5vw, 64px); font-weight: 900; letter-spacing: -2px; margin-bottom: 25px; }
  
  /* ── FOOTER MINIMAL ── */
  .footer-master { border-top: 1px solid var(--border); padding: 80px 0 40px; background: #030305; }
  .footer-master .f-brand { font-size: 24px; font-weight: 800; color: #fff; letter-spacing: -0.5px; margin-bottom: 20px; display: inline-block; cursor: none; }
  .footer-master p { color: var(--text-muted); font-size: 15px; line-height: 1.6; }
  .f-links { list-style: none; padding: 0; }
  .f-links li { margin-bottom: 12px; }
  .f-links a { color: var(--text-muted); transition: color 0.3s; font-size: 15px; cursor: none; }
  .f-links a:hover { color: var(--cyan); }
  .f-bottom { border-top: 1px solid rgba(255,255,255,0.05); margin-top: 60px; padding-top: 30px; display: flex; justify-content: space-between; color: rgba(255,255,255,0.3); font-size: 13px; }
</style>
</head>
