<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ProjectHub — Premium Academic Projects Marketplace</title>
<meta name="description" content="Buy ready-made academic projects with full source code, documentation, PPT &amp; report. BCA, MCA, B.Tech, MBA projects at best prices. Instant download via Razorpay.">
</head>
<body>

<%- include('navbar.ejs') %>

<style>
  /* ─── BASE ─── */
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Inter',sans-serif; background:#090912; color:#fff; overflow-x:hidden; }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
    background: radial-gradient(ellipse 120% 90% at 50% 0%, #1a0828 0%, #0a0a1a 45%, #090912 100%);
  }
  /* Grid lines */
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(233,69,96,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(233,69,96,0.06) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black 0%, transparent 75%);
  }
  /* Glow orbs */
  .orb { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; }
  .orb-1 { width:640px; height:640px; background:radial-gradient(circle, rgba(233,69,96,0.28) 0%, transparent 65%); top:-180px; right:-120px; animation:drift 10s ease-in-out infinite; }
  .orb-2 { width:500px; height:500px; background:radial-gradient(circle, rgba(99,70,229,0.22) 0%, transparent 65%); bottom:-100px; left:-100px; animation:drift 14s ease-in-out infinite reverse; }
  .orb-3 { width:300px; height:300px; background:radial-gradient(circle, rgba(6,182,212,0.14) 0%, transparent 65%); top:40%; left:15%; animation:drift 12s ease-in-out 3s infinite; }
  @keyframes drift { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-36px) scale(1.04)} }

  .hero-content { position:relative; z-index:2; text-align:center; padding:60px 20px 80px; max-width:860px; margin:0 auto; }

  /* Live badge */
  .live-badge {
    display:inline-flex; align-items:center; gap:10px;
    background:rgba(233,69,96,0.12); border:1px solid rgba(233,69,96,0.3);
    color:#f87171; padding:9px 22px; border-radius:50px; font-size:13px; font-weight:600;
    margin-bottom:36px; backdrop-filter:blur(8px);
    animation:fadeDown 0.7s ease both;
  }
  .live-dot { width:8px; height:8px; border-radius:50%; background:#e94560; box-shadow:0 0 0 0 rgba(233,69,96,0.6); animation:ping 1.8s ease infinite; }
  @keyframes ping { 0%{box-shadow:0 0 0 0 rgba(233,69,96,0.7)} 70%{box-shadow:0 0 0 10px transparent} 100%{box-shadow:0 0 0 0 transparent} }

  /* Hero heading */
  .hero h1 {
    font-size: clamp(40px, 7vw, 76px);
    font-weight: 900;
    line-height: 1.07;
    letter-spacing: -2px;
    color: #fff;
    margin-bottom: 28px;
    animation: fadeDown 0.8s 0.1s ease both;
  }
  .glow-text {
    background: linear-gradient(135deg, #e94560 0%, #ff7e92 50%, #ffd93d 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    filter: drop-shadow(0 0 30px rgba(233,69,96,0.45));
  }
  .hero-sub {
    color: rgba(255,255,255,0.58); font-size:18px; line-height:1.75;
    max-width:600px; margin:0 auto 42px;
    animation: fadeDown 0.8s 0.2s ease both;
  }

  /* CTA buttons */
  .hero-btns { display:flex; gap:14px; justify-content:center; flex-wrap:wrap; margin-bottom:40px; animation:fadeDown 0.8s 0.3s ease both; }
  .btn-glow {
    display:inline-flex; align-items:center; gap:9px;
    background:linear-gradient(135deg, #e94560, #c4294a);
    color:#fff; padding:16px 36px; border-radius:14px;
    text-decoration:none; font-weight:700; font-size:15.5px;
    box-shadow:0 8px 32px rgba(233,69,96,0.45);
    transition:all 0.3s;
  }
  .btn-glow:hover { transform:translateY(-4px); box-shadow:0 16px 48px rgba(233,69,96,0.6); color:#fff; }
  .btn-ghost {
    display:inline-flex; align-items:center; gap:9px;
    background:rgba(255,255,255,0.06); color:#fff; padding:16px 36px; border-radius:14px;
    text-decoration:none; font-weight:600; font-size:15.5px;
    border:1.5px solid rgba(255,255,255,0.18);
    transition:all 0.3s; backdrop-filter:blur(8px);
  }
  .btn-ghost:hover { background:rgba(255,255,255,0.12); border-color:rgba(255,255,255,0.4); transform:translateY(-3px); color:#fff; }

  /* Search bar */
  .hero-search {
    display:flex; max-width:520px; margin:0 auto;
    background:rgba(255,255,255,0.06); border:1.5px solid rgba(255,255,255,0.14);
    border-radius:16px; overflow:hidden; backdrop-filter:blur(12px);
    transition:border-color 0.2s; animation:fadeDown 0.8s 0.4s ease both;
  }
  .hero-search:focus-within { border-color:rgba(233,69,96,0.5); }
  .hero-search input {
    flex:1; background:transparent; border:none; color:#fff; padding:14px 20px;
    font-size:14px; font-family:'Inter',sans-serif; outline:none;
  }
  .hero-search input::placeholder { color:rgba(255,255,255,0.38); }
  .hero-search button {
    background:linear-gradient(135deg,#e94560,#c4294a); border:none; color:#fff;
    padding:14px 24px; font-weight:700; font-size:14px; cursor:pointer; transition:background 0.2s;
  }
  .hero-search button:hover { background:linear-gradient(135deg,#ff5572,#e94560); }

  /* Trust chips */
  .trust-chips { display:flex; gap:10px; justify-content:center; flex-wrap:wrap; margin-top:32px; animation:fadeDown 0.8s 0.5s ease both; }
  .chip {
    display:inline-flex; align-items:center; gap:7px;
    background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1);
    color:rgba(255,255,255,0.75); padding:8px 16px; border-radius:40px; font-size:12.5px; font-weight:500;
  }
  .chip-dot { width:7px; height:7px; border-radius:50%; background:#22c55e; animation:ping 2s ease infinite; }

  /* ─── STATS BAR ─── */
  .stats-bar {
    background: linear-gradient(135deg, #e94560 0%, #c4294a 60%, #a01c38 100%);
    padding: 48px 0;
    position: relative; overflow: hidden;
  }
  .stats-bar::before { content:''; position:absolute; inset:0; background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23fff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E"); }
  .stat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; max-width:900px; margin:0 auto; padding:0 24px; }
  .stat-item { text-align:center; }
  .stat-num { font-size:48px; font-weight:900; color:#fff; line-height:1; font-variant-numeric:tabular-nums; }
  .stat-label { font-size:14px; color:rgba(255,255,255,0.8); margin-top:6px; font-weight:500; }
  @media(max-width:600px){ .stat-grid{grid-template-columns:repeat(2,1fr); } .stat-num{font-size:36px;} }

  /* ─── SECTION COMMONS ─── */
  .sec { padding:100px 24px; max-width:1280px; margin:0 auto; }
  .sec-tag { color:#e94560; font-size:12px; font-weight:700; text-transform:uppercase; letter-spacing:2.5px; margin-bottom:12px; }
  .sec-title { font-size:clamp(28px,4vw,44px); font-weight:900; letter-spacing:-1px; margin-bottom:14px; }
  .sec-sub { color:rgba(255,255,255,0.5); font-size:16px; line-height:1.75; max-width:580px; }
  .sec-divider { width:48px; height:4px; border-radius:4px; background:linear-gradient(135deg,#e94560,#c4294a); margin:16px 0 44px; }

  /* ─── CATEGORIES BENTO GRID ─── */
  .categories-section { background:#0c0c1e; }
  .cat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  @media(max-width:900px){ .cat-grid{grid-template-columns:repeat(2,1fr);} }
  @media(max-width:560px){ .cat-grid{grid-template-columns:1fr;} }

  .cat-card {
    position:relative; border-radius:20px; overflow:hidden;
    background:#111127; border:1px solid rgba(255,255,255,0.07);
    text-decoration:none; display:flex; flex-direction:column;
    transition:all 0.4s cubic-bezier(.25,.8,.25,1);
    min-height:260px;
  }
  .cat-card:hover { transform:translateY(-8px); border-color:rgba(233,69,96,0.35); box-shadow:0 20px 60px rgba(0,0,0,0.45), 0 0 0 1px rgba(233,69,96,0.15); }

  .cat-img { position:absolute; inset:0; }
  .cat-img img { width:100%; height:100%; object-fit:cover; opacity:0.28; transition:all 0.5s; }
  .cat-card:hover .cat-img img { opacity:0.42; transform:scale(1.06); }
  .cat-overlay { position:absolute; inset:0; background:linear-gradient(to top, rgba(8,8,20,0.95) 0%, rgba(8,8,20,0.5) 50%, transparent 100%); }

  .cat-badge-pill {
    position:absolute; top:16px; left:16px; z-index:3;
    background:linear-gradient(135deg,#e94560,#c4294a); color:#fff;
    font-size:11px; font-weight:700; padding:5px 13px; border-radius:20px;
    box-shadow:0 4px 12px rgba(233,69,96,0.4);
  }

  .cat-content { position:relative; z-index:2; margin-top:auto; padding:22px 22px 24px; }
  .cat-emoji { font-size:28px; margin-bottom:10px; display:block; }
  .cat-name { font-size:17px; font-weight:800; color:#fff; margin-bottom:6px; }
  .cat-desc { font-size:13px; color:rgba(255,255,255,0.55); line-height:1.55; margin-bottom:14px; }
  .cat-footer { display:flex; align-items:center; justify-content:space-between; }
  .cat-price { font-size:16px; font-weight:800; color:#e94560; }
  .cat-arrow {
    width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    background:rgba(233,69,96,0.15); color:#e94560; font-size:13px;
    transition:all 0.25s;
  }
  .cat-card:hover .cat-arrow { background:#e94560; color:#fff; }

  /* ─── HOW IT WORKS ─── */
  .how-section { background:#090912; }
  .steps-row { display:grid; grid-template-columns:repeat(3,1fr); gap:28px; position:relative; }
  @media(max-width:760px){ .steps-row{grid-template-columns:1fr;} }
  .steps-row::before {
    content:''; position:absolute; top:50px; left:16.6%; right:16.6%; height:2px;
    background:linear-gradient(to right, #e94560, rgba(233,69,96,0.15), #e94560);
    pointer-events:none;
  }
  @media(max-width:760px){ .steps-row::before{display:none;} }
  .step-card { text-align:center; padding:36px 28px; background:#111127; border:1px solid rgba(255,255,255,0.07); border-radius:20px; position:relative; }
  .step-num {
    width:64px; height:64px; margin:0 auto 20px;
    background:linear-gradient(135deg,#e94560,#c4294a);
    border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:24px; font-weight:900; color:#fff;
    box-shadow:0 8px 28px rgba(233,69,96,0.45);
    position:relative; z-index:2;
  }
  .step-card h5 { font-size:17px; font-weight:800; color:#fff; margin-bottom:10px; }
  .step-card p { font-size:13.5px; color:rgba(255,255,255,0.5); line-height:1.6; }

  /* ─── WHY CHOOSE US ─── */
  .features-section { background:#0c0c1e; }
  .feat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  @media(max-width:900px){ .feat-grid{grid-template-columns:repeat(2,1fr);} }
  @media(max-width:560px){ .feat-grid{grid-template-columns:1fr;} }
  .feat-card { background:#111127; border:1px solid rgba(255,255,255,0.07); border-radius:20px; padding:32px 28px; transition:all 0.3s; }
  .feat-card:hover { border-color:rgba(233,69,96,0.3); transform:translateY(-5px); box-shadow:0 16px 40px rgba(0,0,0,0.4); }
  .feat-icon { width:58px; height:58px; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:26px; margin-bottom:18px; }
  .feat-card h5 { font-size:16.5px; font-weight:800; color:#fff; margin-bottom:9px; }
  .feat-card p { font-size:13.5px; color:rgba(255,255,255,0.5); line-height:1.65; }

  /* ─── TESTIMONIALS ─── */
  .testi-section { background:#090912; }
  .testi-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  @media(max-width:900px){ .testi-grid{grid-template-columns:repeat(2,1fr);} }
  @media(max-width:560px){ .testi-grid{grid-template-columns:1fr;} }
  .testi-card { background:#111127; border:1px solid rgba(255,255,255,0.07); border-radius:20px; padding:28px; position:relative; }
  .testi-card::before { content:'❝'; position:absolute; top:20px; right:24px; font-size:42px; color:rgba(233,69,96,0.18); line-height:1; }
  .testi-stars { color:#fbbf24; font-size:16px; margin-bottom:14px; letter-spacing:2px; }
  .testi-text { font-size:14px; color:rgba(255,255,255,0.7); line-height:1.75; font-style:italic; margin-bottom:20px; }
  .testi-author { display:flex; align-items:center; gap:12px; }
  .testi-avatar { width:46px; height:46px; border-radius:50%; object-fit:cover; border:2px solid rgba(233,69,96,0.4); }
  .testi-name { font-size:14px; font-weight:700; color:#fff; }
  .testi-college { font-size:12px; color:rgba(255,255,255,0.42); margin-top:2px; }

  /* ─── PROMOTIONAL BANNER ─── */
  .promo-banner {
    position:relative; overflow:hidden;
    background:linear-gradient(135deg, #0f0f22 0%, #1a0828 50%, #0a1025 100%);
    padding:80px 24px;
    border-top:1px solid rgba(233,69,96,0.15);
    border-bottom:1px solid rgba(233,69,96,0.15);
  }
  .promo-banner::before { content:''; position:absolute; inset:0; background:radial-gradient(ellipse 60% 80% at 50% 50%, rgba(233,69,96,0.18), transparent 70%); pointer-events:none; }
  .promo-inner { position:relative; z-index:2; text-align:center; max-width:720px; margin:0 auto; }
  .promo-inner h2 { font-size:clamp(28px,5vw,46px); font-weight:900; letter-spacing:-1px; margin-bottom:14px; }
  .promo-inner p { color:rgba(255,255,255,0.62); font-size:17px; line-height:1.7; margin-bottom:34px; }

  /* ─── FINAL CTA ─── */
  .final-cta { background:#090912; padding:80px 24px; text-align:center; border-top:1px solid rgba(255,255,255,0.05); }
  .final-cta h2 { font-size:clamp(30px,5vw,50px); font-weight:900; letter-spacing:-1.5px; margin-bottom:14px; }
  .final-cta p { color:rgba(255,255,255,0.52); font-size:17px; margin-bottom:36px; }

  /* ─── FOOTER ─── */
  .site-footer { background:#06060f; color:rgba(255,255,255,0.55); padding:72px 24px 36px; border-top:1px solid rgba(255,255,255,0.06); }
  .footer-inner { max-width:1280px; margin:0 auto; }
  .footer-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1fr 1fr; gap:32px; margin-bottom:48px; }
  @media(max-width:900px){ .footer-grid{grid-template-columns:1fr 1fr 1fr;} }
  @media(max-width:560px){ .footer-grid{grid-template-columns:1fr 1fr;} }
  .footer-brand-logo { font-size:22px; font-weight:900; color:#fff; margin-bottom:14px; }
  .footer-brand-logo span { color:#e94560; }
  .footer-desc { font-size:13.5px; line-height:1.7; color:rgba(255,255,255,0.45); margin-bottom:18px; }
  .footer-socials { display:flex; gap:12px; }
  .footer-socials a { width:38px; height:38px; background:rgba(233,69,96,0.12); border:1px solid rgba(233,69,96,0.25); border-radius:10px; display:flex; align-items:center; justify-content:center; color:#e94560; font-size:16px; transition:all 0.2s; }
  .footer-socials a:hover { background:#e94560; color:#fff; border-color:transparent; }
  .footer-col h6 { font-size:13px; font-weight:700; color:#fff; text-transform:uppercase; letter-spacing:1px; margin-bottom:16px; }
  .footer-col a { display:block; color:rgba(255,255,255,0.5); text-decoration:none; font-size:13.5px; margin-bottom:10px; transition:color 0.2s; }
  .footer-col a:hover { color:#e94560; }
  .footer-hr { border:none; border-top:1px solid rgba(255,255,255,0.08); margin-bottom:24px; }
  .footer-bottom { display:flex; justify-content:space-between; flex-wrap:wrap; gap:8px; font-size:12.5px; color:rgba(255,255,255,0.32); }

  /* ─── REVEAL ANIMATION ─── */
  .reveal { opacity:0; transform:translateY(28px); transition:opacity 0.65s ease, transform 0.65s ease; }
  .reveal.visible { opacity:1; transform:translateY(0); }

  /* ─── KEYFRAMES ─── */
  @keyframes fadeDown { from{opacity:0;transform:translateY(-18px)} to{opacity:1;transform:translateY(0)} }
</style>

<!-- ═══════════ HERO ═══════════ -->
<section class="hero">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="hero-content">

    <div class="live-badge">
      <div class="live-dot"></div>
      🎓 India's #1 Academic Projects Marketplace
    </div>

    <h1>
      Get Your <span class="glow-text">Dream Project</span><br>
      Ready to Submit!
    </h1>

    <p class="hero-sub">
      500+ premium academic projects across 14 tech categories —<br>
      Web Dev, AI/ML, Mobile, Blockchain &amp; more.<br>
      Full source code + documentation + PPT included.
    </p>

    <div class="hero-btns">
      <a href="/ready-project-details" class="btn-glow"><i class="fas fa-rocket"></i> Browse All Projects</a>
      <a href="/customized-project-details" class="btn-ghost"><i class="fas fa-pencil-ruler"></i> Custom Project</a>
    </div>

    <form class="hero-search" onsubmit="searchProject(event)">
      <input type="text" id="heroSearch" placeholder="Search by technology, title, category..." autocomplete="off">
      <button type="submit"><i class="fas fa-search"></i> Search</button>
    </form>

    <div class="trust-chips">
      <div class="chip"><div class="chip-dot"></div> ⚡ Instant Download</div>
      <div class="chip"><div class="chip-dot"></div> 🔒 Secure Razorpay</div>
      <div class="chip"><div class="chip-dot"></div> 📄 Full Documentation</div>
      <div class="chip"><div class="chip-dot"></div> 🌟 4.9★ Rating</div>
    </div>
  </div>
</section>

<!-- ═══════════ STATS ═══════════ -->
<section class="stats-bar">
  <div class="stat-grid">
    <div class="stat-item reveal">
      <div class="stat-num" data-target="500">0</div>
      <div class="stat-label">Premium Projects</div>
    </div>
    <div class="stat-item reveal">
      <div class="stat-num" data-target="15000">0</div>
      <div class="stat-label">Students Helped</div>
    </div>
    <div class="stat-item reveal">
      <div class="stat-num" data-target="14">0</div>
      <div class="stat-label">Tech Categories</div>
    </div>
    <div class="stat-item reveal">
      <div class="stat-num">4.9★</div>
      <div class="stat-label">Average Rating</div>
    </div>
  </div>
</section>

<!-- ═══════════ CATEGORIES ═══════════ -->
<section class="categories-section">
  <div class="sec">
    <div class="reveal">
      <div class="sec-tag">Explore Categories</div>
      <h2 class="sec-title">Browse All<br>Project Categories</h2>
      <p class="sec-sub">From basic mini-projects to advanced AI/Blockchain solutions — we have everything you need.</p>
      <div class="sec-divider"></div>
    </div>

    <div class="cat-grid">

      <!-- 1: Ready Projects -->
      <a href="/ready-project-details" class="cat-card reveal">
        <div class="cat-img"><img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=600&q=70" alt="Ready Projects" loading="lazy"></div>
        <div class="cat-overlay"></div>
        <span class="cat-badge-pill">🔥 Most Popular</span>
        <div class="cat-content">
          <span class="cat-emoji">🚀</span>
          <div class="cat-name">Ready Projects</div>
          <div class="cat-desc">Complete, tested projects ready to submit with source code, docs &amp; PPT.</div>
          <div class="cat-footer"><div class="cat-price">From ₹299</div><div class="cat-arrow"><i class="fas fa-arrow-right"></i></div></div>
        </div>
      </a>

      <!-- 2: Mini Projects -->
      <a href="/mini-project-details" class="cat-card reveal">
        <div class="cat-img"><img src="https://images.unsplash.com/photo-1542831371-29b0f74f9713?w=600&q=70" alt="Mini Projects" loading="lazy"></div>
        <div class="cat-overlay"></div>
        <span class="cat-badge-pill">💡 Beginner Friendly</span>
        <div class="cat-content">
          <span class="cat-emoji">📦</span>
          <div class="cat-name">Mini Projects</div>
          <div class="cat-desc">Small, focused academic mini-projects perfect for BCA/B.Tech first &amp; second year.</div>
          <div class="cat-footer"><div class="cat-price">From ₹199</div><div class="cat-arrow"><i class="fas fa-arrow-right"></i></div></div>
        </div>
      </a>

