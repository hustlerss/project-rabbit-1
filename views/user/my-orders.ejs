<%- include('navbar.ejs') %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders | Project Rabbit</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #f4f6f9; }
        .hero { background: linear-gradient(135deg, #1a1a2e, #0f3460); color: #fff; padding: 50px 0 40px; text-align: center; }
        .hero h1 { font-weight: 800; font-size: 36px; }
        .order-card { background: #fff; border-radius: 14px; box-shadow: 0 3px 20px rgba(0,0,0,0.08); margin-bottom: 20px; overflow: hidden; }
        .order-header { background: #f8f9fa; padding: 15px 20px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        .order-body { padding: 20px; }
        .badge-paid { background: #28a745; color: #fff; padding: 5px 14px; border-radius: 20px; font-size: 12px; }
        .btn-download { background: linear-gradient(135deg, #e94560, #c4294a); color: #fff; border: none; border-radius: 10px; padding: 9px 20px; font-weight: 600; text-decoration: none; transition: all 0.3s; }
        .btn-download:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(233,69,96,0.35); color: #fff; }
        .search-box { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.3); color: #fff; border-radius: 30px; padding: 12px 20px; width: 400px; max-width: 90%; }
        .search-box::placeholder { color: rgba(255,255,255,0.6); }
        .search-box:focus { outline: none; background: rgba(255,255,255,0.15); }
    </style>
</head>
<body>

<div class="hero">
    <h1><i class="fas fa-box me-2" style="color:#e94560;"></i>My Orders</h1>
    <p class="opacity-75 mb-4">Find and download your purchased projects</p>
    <form method="GET" action="/my-orders" class="d-flex justify-content-center gap-2 flex-wrap">
        <input type="email" name="email" class="search-box" placeholder="Enter your email to find orders..." value="<%= email %>" required>
        <button type="submit" class="btn" style="background:#e94560;color:#fff;border-radius:30px;padding:12px 25px;font-weight:600;">
            <i class="fas fa-search me-1"></i> Search
        </button>
    </form>
</div>

<div class="container my-5" style="max-width:900px;">
    <% if (email && orders.length === 0) { %>
        <div class="text-center py-5">
            <div style="font-size:60px;">📭</div>
            <h4 class="mt-3 text-muted">No orders found for <strong><%= email %></strong></h4>
            <p class="text-muted">If you made a purchase, check the email address and try again.</p>
            <a href="/" class="btn btn-outline-danger mt-2">Browse Projects</a>
        </div>
    <% } else if (orders.length > 0) { %>
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold"><%= orders.length %> order(s) found for <span class="text-danger"><%= email %></span></h5>
        </div>
        <% orders.forEach((order, i) => { %>
        <div class="order-card">
            <div class="order-header">
                <div>
                    <small class="text-muted">Order #<%= i + 1 %></small>
                    <div class="fw-bold"><%= order.project_title %></div>
                    <small class="text-muted">
                        <i class="fas fa-calendar me-1"></i>
                        <%= new Date(order.created_at).toLocaleDateString('en-IN', { day:'2-digit', month:'long', year:'numeric' }) %>
                    </small>
                </div>
                <div class="text-end">
                    <span class="badge-paid"><i class="fas fa-check me-1"></i><%= order.status %></span>
                    <div class="fw-bold mt-1 text-success fs-5">₹<%= parseFloat(order.amount).toFixed(2) %></div>
                </div>
            </div>
            <div class="order-body d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <div class="mb-1"><i class="fas fa-fingerprint me-2 text-muted"></i><small class="text-muted">Payment ID: </small><code><%= order.payment_id %></code></div>
                    <div><i class="fas fa-tag me-2 text-muted"></i><small class="badge bg-light text-dark border"><%= order.project_type %></small></div>
                </div>
                <a href="/download/<%= order.payment_id %>/<%= order.project_type %>/<%= order.project_id %>" class="btn-download">
                    <i class="fas fa-download me-2"></i>Download Project
                </a>
            </div>
        </div>
        <% }) %>
    <% } else { %>
        <div class="text-center py-5">
            <div style="font-size:60px;">🔍</div>
            <h4 class="mt-3 text-muted">Enter your email address above to find your orders</h4>
        </div>
    <% } %>
</div>

<%- include('footer.ejs') %>
</body>
</html>
