<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact Requests | ProjectHub Admin</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
</head>
<body>
<%- include('sidebar.ejs') %>
<div class="ph-main">
  <div class="topbar"><h6 style="margin:0;font-weight:700">Contact Requests</h6><a href="/admin/logout" class="btn btn-sm btn-outline-danger">Logout</a></div>
  
<div class="d-flex justify-content-between align-items-center mb-3">
  <h5 class="fw-bold mb-0">Contact Requests <span class="badge bg-secondary ms-2"><%=comments.length%></span></h5>
</div>
<div class="table-card">
<table class="table table-hover mb-0">
<thead class="table-dark"><tr><th>#</th><th>Name</th><th>Email</th><th>Message</th><th>Date</th><th>Action</th></tr></thead>
<tbody>
<% comments.forEach((c,i) => { %>
<tr>
<td><%=i+1%></td>
<td><strong><%=c.name%></strong></td>
<td><%=c.email%></td>
<td><small><%=c.message?c.message.substring(0,80)+'...':''%></small></td>
<td><small><%=c.created_at?new Date(c.created_at).toLocaleDateString('en-IN'):''%></small></td>
<td><a href="/admin/delete-contact/<%=c.id%>" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')">Delete</a></td>
</tr>
<% }) %>
<% if(!comments.length){ %><tr><td colspan="6" class="text-center py-4 text-muted">No contact requests yet.</td></tr><% } %>
</tbody>
</table>
</div>
</div><!-- /ph-main -->
</body></html>