<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Orders Management | ProjectHub Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    .page-header { background: linear-gradient(135deg, #1a1a2e, #0f3460); color: #fff; padding: 28px 30px; border-radius: 14px; margin-bottom: 24px; }
    .page-header h2 { font-size: 22px; font-weight: 800; margin: 0 0 4px; }
    .page-header p  { margin: 0; opacity: .7; font-size: 13px; }
    .stats-card { background: #fff; border-radius: 12px; padding: 20px 22px; box-shadow: 0 2px 15px rgba(0,0,0,.07); border-left: 4px solid #e94560; }
    .stats-card h6 { color: #888; font-size: 12px; margin-bottom: 6px; }
    .stats-card h3 { font-size: 28px; font-weight: 800; margin: 0; }
    .table-card { background: #fff; border-radius: 14px; box-shadow: 0 2px 15px rgba(0,0,0,.07); overflow: hidden; }
    .badge-paid   { background: #28a745; color: #fff; padding: 5px 12px; border-radius: 20px; font-size: 11.5px; font-weight:600; }
    .badge-pending{ background: #ffc107; color: #000; padding: 5px 12px; border-radius: 20px; font-size: 11.5px; font-weight:600; }
    .badge-failed { background: #dc3545; color: #fff; padding: 5px 12px; border-radius: 20px; font-size: 11.5px; font-weight:600; }
  </style>
</head>
<body>

<%- include('sidebar.ejs') %>

<div class="ph-main">

  <!-- Page Header -->
  <div class="page-header">
    <h2><i class="fas fa-shopping-cart me-2"></i>Orders / Payment Management</h2>
    <p>All Razorpay transactions &amp; purchases</p>
  </div>

  <!-- Stats Row -->
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
      <div class="stats-card">
        <h6>Total Orders</h6>
        <h3><%= orders.length %></h3>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stats-card" style="border-left-color:#28a745;">
        <h6>Paid Orders</h6>
        <h3 class="text-success"><%= orders.filter(o => o.status === 'PAID').length %></h3>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stats-card" style="border-left-color:#007bff;">
        <h6>Total Revenue</h6>
        <h3 class="text-primary">₹<%= orders.filter(o => o.status === 'PAID').reduce((s,o) => s + parseFloat(o.amount||0), 0).toFixed(0) %></h3>
      </div>
    </div>
    <div class="col-6 col-md-3">
      <div class="stats-card" style="border-left-color:#ffc107;">
        <h6>Pending Orders</h6>
        <h3 class="text-warning"><%= orders.filter(o => o.status !== 'PAID').length %></h3>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="table-card">
    <div class="p-3 border-bottom d-flex flex-wrap gap-2 justify-content-between align-items-center">
      <h5 class="mb-0 fw-bold">All Orders</h5>
      <input type="text" class="form-control" style="max-width:240px;" placeholder="Search orders..." id="searchInput" onkeyup="searchTable()">
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0" id="ordersTable">
        <thead class="table-dark">
          <tr>
            <th>#</th>
            <th>Order ID</th>
            <th>Buyer</th>
            <th>Project</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Date</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (orders.length === 0) { %>
          <tr><td colspan="8" class="text-center py-4 text-muted">No orders yet.</td></tr>
          <% } %>
          <% orders.forEach((order, i) => { %>
          <tr>
            <td><%= i + 1 %></td>
            <td>
              <small class="text-muted d-block"><%= order.order_id %></small>
              <small class="text-info">Pay: <%= order.payment_id %></small>
            </td>
            <td>
              <strong><%= order.buyer_name %></strong><br>
              <small class="text-muted"><%= order.buyer_email %></small><br>
              <small class="text-muted"><%= order.buyer_phone %></small>
            </td>
            <td>
              <strong><%= order.project_title %></strong><br>
              <span class="badge bg-secondary"><%= order.project_type %></span>
            </td>
            <td class="fw-bold text-success">₹<%= parseFloat(order.amount).toFixed(2) %></td>
            <td>
              <% if (order.status === 'PAID') { %>
                <span class="badge-paid">✅ PAID</span>
              <% } else if (order.status === 'PENDING') { %>
                <span class="badge-pending">⏳ PENDING</span>
              <% } else { %>
                <span class="badge-failed">❌ FAILED</span>
              <% } %>
            </td>
            <td><small><%= new Date(order.created_at).toLocaleDateString('en-IN') %></small></td>
            <td>
              <a href="/admin/order-details/<%= order.id %>" class="btn btn-sm btn-info me-1">View</a>
              <a href="/admin/delete-order/<%= order.id %>" class="btn btn-sm btn-danger" onclick="return confirm('Delete this order?')">Delete</a>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div><!-- /ph-main -->

<script>
function searchTable() {
  const v = document.getElementById('searchInput').value.toUpperCase();
  document.querySelectorAll('#ordersTable tbody tr').forEach(r => {
    r.style.display = r.textContent.toUpperCase().includes(v) ? '' : 'none';
  });
}
</script>
</body>
</html>
