<%- include('navbar.ejs') %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders Management | Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background: #f8f9fa; }
        .page-header { background: linear-gradient(135deg, #1a1a2e, #0f3460); color: #fff; padding: 30px; border-radius: 15px; margin-bottom: 25px; }
        .stats-card { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 2px 15px rgba(0,0,0,0.08); border-left: 4px solid #e94560; }
        .table-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 15px rgba(0,0,0,0.08); overflow: hidden; }
        .badge-paid { background: #28a745; color: #fff; padding: 5px 12px; border-radius: 20px; font-size: 12px; }
        .badge-pending { background: #ffc107; color: #000; padding: 5px 12px; border-radius: 20px; font-size: 12px; }
        .badge-failed { background: #dc3545; color: #fff; padding: 5px 12px; border-radius: 20px; font-size: 12px; }
        .action-btn { padding: 4px 10px; border-radius: 6px; font-size: 12px; }
    </style>
</head>
<body>
<div class="container-fluid mt-4" style="max-width:1300px;">
    <div class="page-header">
        <h2><i class="fas fa-shopping-cart me-2"></i>Orders / Payment Management</h2>
        <p class="mb-0 opacity-75">All Razorpay transactions & purchases</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stats-card">
                <h6 class="text-muted">Total Orders</h6>
                <h3 class="fw-bold"><%= orders.length %></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card" style="border-left-color:#28a745;">
                <h6 class="text-muted">Paid Orders</h6>
                <h3 class="fw-bold text-success"><%= orders.filter(o => o.status === 'PAID').length %></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card" style="border-left-color:#007bff;">
                <h6 class="text-muted">Total Revenue</h6>
                <h3 class="fw-bold text-primary">₹<%= orders.filter(o => o.status === 'PAID').reduce((sum, o) => sum + parseFloat(o.amount || 0), 0).toFixed(2) %></h3>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stats-card" style="border-left-color:#ffc107;">
                <h6 class="text-muted">Pending Orders</h6>
                <h3 class="fw-bold text-warning"><%= orders.filter(o => o.status !== 'PAID').length %></h3>
            </div>
        </div>
    </div>

    <div class="table-card">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">All Orders</h5>
            <input type="text" class="form-control w-25" placeholder="Search orders..." id="searchInput" onkeyup="searchTable()">
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="ordersTable">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Order ID</th>
                        <th>Buyer</th>
                        <th>Project</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (orders.length === 0) { %>
                    <tr><td colspan="8" class="text-center py-4 text-muted">No orders yet.</td></tr>
                    <% } %>
                    <% orders.forEach((order, i) => { %>
                    <tr>
                        <td><%= i + 1 %></td>
                        <td>
                            <small class="text-muted"><%= order.order_id %></small><br>
                            <small class="text-info">Pay: <%= order.payment_id %></small>
                        </td>
                        <td>
                            <strong><%= order.buyer_name %></strong><br>
                            <small class="text-muted"><%= order.buyer_email %></small><br>
                            <small class="text-muted"><%= order.buyer_phone %></small>
                        </td>
                        <td>
                            <strong><%= order.project_title %></strong><br>
                            <small class="badge bg-secondary"><%= order.project_type %></small>
                        </td>
                        <td class="fw-bold text-success">₹<%= parseFloat(order.amount).toFixed(2) %></td>
                        <td>
                            <% if (order.status === 'PAID') { %>
                                <span class="badge-paid">✅ PAID</span>
                            <% } else if (order.status === 'PENDING') { %>
                                <span class="badge-pending">⏳ PENDING</span>
                            <% } else { %>
                                <span class="badge-failed">❌ FAILED</span>
                            <% } %>
                        </td>
                        <td><small><%= new Date(order.created_at).toLocaleDateString('en-IN') %></small></td>
                        <td>
                            <a href="/admin/order-details/<%= order.id %>" class="btn btn-sm btn-info action-btn">View</a>
                            <a href="/admin/delete-order/<%= order.id %>" class="btn btn-sm btn-danger action-btn" onclick="return confirm('Delete this order?')">Delete</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
<script>
function searchTable() {
    const input = document.getElementById('searchInput').value.toUpperCase();
    const rows = document.querySelectorAll('#ordersTable tbody tr');
    rows.forEach(row => {
        row.style.display = row.textContent.toUpperCase().includes(input) ? '' : 'none';
    });
}
</script>
</body>
</html>
