<!-- ════════════════════════════════════════
     ProjectHub — Shared Admin Sidebar
════════════════════════════════════════ -->
<style>
  *,*::before,*::after{box-sizing:border-box;}
  body{font-family:'Segoe UI',sans-serif;background:#f0f2f5;display:flex;min-height:100vh;margin:0;}

  /* ── Sidebar ── */
  .ph-sidebar{
    width:250px;background:linear-gradient(180deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);
    color:#fff;position:fixed;top:0;left:0;height:100vh;
    overflow-y:auto;z-index:200;transition:transform .3s;
    scrollbar-width:thin;scrollbar-color:rgba(233,69,96,.4) transparent;
  }
  .ph-sidebar::-webkit-scrollbar{width:4px;}
  .ph-sidebar::-webkit-scrollbar-thumb{background:rgba(233,69,96,.4);border-radius:4px;}

  .ph-sidebar-brand{padding:22px 20px 18px;border-bottom:1px solid rgba(255,255,255,.08);}
  .ph-sidebar-brand .brand-name{color:#e94560;font-weight:900;font-size:18px;text-decoration:none;display:block;margin-bottom:3px;}
  .ph-sidebar-brand small{color:rgba(255,255,255,.38);font-size:11px;text-transform:uppercase;letter-spacing:1px;}

  .ph-sidebar-nav{padding:12px 0 60px;}
  .ph-menu-label{color:rgba(255,255,255,.3);font-size:9.5px;font-weight:700;letter-spacing:1.8px;padding:12px 20px 4px;text-transform:uppercase;}
  .ph-menu-divider{border-top:1px solid rgba(255,255,255,.07);margin:6px 0;}

  .ph-sidebar-nav a{
    display:flex;align-items:center;gap:11px;
    padding:10px 20px;color:rgba(255,255,255,.7);
    text-decoration:none;font-size:13px;font-weight:500;
    border-left:3px solid transparent;transition:all .2s;
  }
  .ph-sidebar-nav a:hover,.ph-sidebar-nav a.active{
    background:rgba(233,69,96,.14);color:#fff;border-left-color:#e94560;
  }
  .ph-sidebar-nav a i{width:16px;text-align:center;font-size:13px;opacity:.85;}
  .ph-sidebar-nav a.logout-link{color:#f87171;}
  .ph-sidebar-nav a.logout-link:hover{background:rgba(233,69,96,.2);}

  /* ── Main area offset ── */
  .ph-main{margin-left:250px;flex:1;padding:24px;min-height:100vh;}

  /* ── Mobile hamburger ── */
  .ph-ham{
    display:none;position:fixed;top:14px;left:14px;z-index:300;
    background:#e94560;border:none;border-radius:9px;width:40px;height:40px;
    align-items:center;justify-content:center;color:#fff;font-size:16px;cursor:pointer;
    box-shadow:0 4px 12px rgba(233,69,96,.5);
  }
  .ph-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:150;}

  @media(max-width:768px){
    .ph-sidebar{transform:translateX(-100%);}
    .ph-sidebar.open{transform:translateX(0);}
    .ph-main{margin-left:0;padding:20px 14px;padding-top:68px;}
    .ph-ham{display:flex;}
    .ph-overlay.show{display:block;}
  }
</style>

<button class="ph-ham" id="phHam" aria-label="Toggle sidebar"><i class="fas fa-bars"></i></button>
<div class="ph-overlay" id="phOverlay"></div>

<nav class="ph-sidebar" id="phSidebar">
  <div class="ph-sidebar-brand">
    <a href="/admin" class="brand-name">⚡ ProjectHub</a>
    <small>Admin Control Panel</small>
  </div>

  <div class="ph-sidebar-nav">
    <div class="ph-menu-label">Main</div>
    <a href="/admin" id="sNav-dash"><i class="fas fa-th-large"></i> Dashboard</a>
    <a href="/admin/orders" id="sNav-orders"><i class="fas fa-shopping-cart"></i> Orders / Payments</a>
    <a href="/admin/contact-request-list" id="sNav-contact"><i class="fas fa-envelope"></i> Contact Requests</a>

    <div class="ph-menu-divider"></div>
    <div class="ph-menu-label">Projects</div>
    <a href="/admin/ready-project-list"><i class="fas fa-rocket"></i> Ready Projects</a>
    <a href="/admin/mini-project-list"><i class="fas fa-cube"></i> Mini Projects</a>
    <a href="/admin/bundle-project-list"><i class="fas fa-boxes"></i> Bundle Projects</a>
    <a href="/admin/customized-project-list"><i class="fas fa-pencil-ruler"></i> Customized</a>
    <a href="/admin/ecommerce-project-list"><i class="fas fa-store"></i> E-Commerce</a>
    <a href="/admin/web-development-project-list"><i class="fas fa-globe"></i> Web Development</a>
    <a href="/admin/fullstack-project-list"><i class="fas fa-layer-group"></i> Full Stack</a>
    <a href="/admin/mobile-project-list"><i class="fas fa-mobile-alt"></i> Mobile Apps</a>
    <a href="/admin/ai-project-list"><i class="fas fa-brain"></i> AI / ML</a>
    <a href="/admin/ds-project-list"><i class="fas fa-chart-bar"></i> Data Science</a>
    <a href="/admin/gaming-project-list"><i class="fas fa-gamepad"></i> Gaming</a>
    <a href="/admin/cyber-project-list"><i class="fas fa-shield-alt"></i> Cyber Security</a>
    <a href="/admin/blockchain-project-list"><i class="fas fa-link"></i> Blockchain</a>
    <a href="/admin/cloud-project-list"><i class="fas fa-cloud"></i> Cloud & DevOps</a>
    <a href="/admin/elearning-project-list"><i class="fas fa-graduation-cap"></i> E-Learning</a>

    <div class="ph-menu-divider"></div>
    <div class="ph-menu-label">Content</div>
    <a href="/admin/view-categories"><i class="fas fa-tags"></i> Categories</a>
    <a href="/admin/view-roadmaps"><i class="fas fa-road"></i> Roadmaps</a>
    <a href="/" target="_blank"><i class="fas fa-external-link-alt"></i> View Website</a>

    <div class="ph-menu-divider"></div>
    <a href="/admin/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</nav>

<script>
  // Active link
  const path = window.location.pathname;
  document.querySelectorAll('.ph-sidebar-nav a').forEach(a => {
    if (a.getAttribute('href') === path || (path !== '/admin' && path.startsWith(a.getAttribute('href')) && a.getAttribute('href') !== '/admin')) {
      a.classList.add('active');
    }
    if (path === '/admin' && a.getAttribute('href') === '/admin') a.classList.add('active');
  });
  // Hamburger toggle
  const ham = document.getElementById('phHam');
  const sidebar = document.getElementById('phSidebar');
  const overlay = document.getElementById('phOverlay');
  function closeSidebar(){ sidebar.classList.remove('open'); overlay.classList.remove('show'); }
  ham.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('show'); });
  overlay.addEventListener('click', closeSidebar);
</script>
