<%- include('navbar.ejs') %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Details | Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f8f9fa; }
        .detail-card { background: #fff; border-radius: 15px; box-shadow: 0 2px 20px rgba(0,0,0,0.1); padding: 30px; }
        .info-row { padding: 12px 0; border-bottom: 1px solid #f0f0f0; }
        .info-row:last-child { border: none; }
    </style>
</head>
<body>
<div class="container mt-4" style="max-width:900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Order Details</h3>
        <a href="/admin/orders" class="btn btn-outline-secondary">← Back to Orders</a>
    </div>
    <div class="detail-card">
        <div class="row">
            <div class="col-md-6">
                <h5 class="fw-bold text-muted mb-3">Payment Info</h5>
                <div class="info-row"><strong>Order ID:</strong> <code><%= order.order_id %></code></div>
                <div class="info-row"><strong>Payment ID:</strong> <code><%= order.payment_id %></code></div>
                <div class="info-row"><strong>Status:</strong> 
                    <span class="badge bg-<%= order.status === 'PAID' ? 'success' : order.status === 'PENDING' ? 'warning' : 'danger' %>"><%= order.status %></span>
                </div>
                <div class="info-row"><strong>Amount:</strong> <span class="text-success fw-bold fs-5">₹<%= parseFloat(order.amount).toFixed(2) %></span></div>
                <div class="info-row"><strong>Date:</strong> <%= new Date(order.created_at).toLocaleString('en-IN') %></div>
            </div>
            <div class="col-md-6">
                <h5 class="fw-bold text-muted mb-3">Buyer Info</h5>
                <div class="info-row"><strong>Name:</strong> <%= order.buyer_name %></div>
                <div class="info-row"><strong>Email:</strong> <%= order.buyer_email %></div>
                <div class="info-row"><strong>Phone:</strong> <%= order.buyer_phone %></div>
                <h5 class="fw-bold text-muted mb-3 mt-3">Project Info</h5>
                <div class="info-row"><strong>Title:</strong> <%= order.project_title %></div>
                <div class="info-row"><strong>Type:</strong> <span class="badge bg-secondary"><%= order.project_type %></span></div>
                <div class="info-row"><strong>Project ID:</strong> <%= order.project_id %></div>
            </div>
        </div>
        <div class="mt-4">
            <h5 class="fw-bold text-muted mb-3">Update Status</h5>
            <form method="POST" action="/admin/update-order-status/<%= order.id %>">
                <div class="d-flex gap-3">
                    <select name="status" class="form-select" style="max-width:200px;">
                        <option value="PAID" <%= order.status === 'PAID' ? 'selected' : '' %>>PAID</option>
                        <option value="PENDING" <%= order.status === 'PENDING' ? 'selected' : '' %>>PENDING</option>
                        <option value="FAILED" <%= order.status === 'FAILED' ? 'selected' : '' %>>FAILED</option>
                        <option value="REFUNDED" <%= order.status === 'REFUNDED' ? 'selected' : '' %>>REFUNDED</option>
                    </select>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </div>
            </form>
        </div>
    </div>
</div>
</body>
</html>
